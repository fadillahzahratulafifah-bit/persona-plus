rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
      // Admin can update any user (suspend/activate)
      allow update: if request.auth != null;
    }

    // Services collection (MUA services and costumes)
    match /services/{serviceId} {
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.vendorId;
    }

    // Orders collection
    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Chats collection (real-time messaging)
    match /chats/{chatId} {
      // Only participants can read/write chat rooms
      allow read, write: if request.auth != null && 
        request.auth.uid in resource.data.participants;
      // Allow creating a new chat room
      allow create: if request.auth != null;

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth != null;
      }
    }
  }
}
